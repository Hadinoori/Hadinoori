---
import Base from '../layouts/Base.astro';
import HeroCanvas from '../components/HeroCanvas.astro';
import { getCollection } from 'astro:content';

const allInsights = await getCollection('insights', ({ data }) =>
  data.status === 'published'
);

const featured = allInsights
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<Base
  title="Hadi Noori"
  description="Hadi Noori works at the intersection of AI governance, digital transformation, algorithmic accountability, and socio-technical risk."
  canonical="https://hadinoori.ca/"
>

  <!-- HERO -->
  <section class="hero">
    <HeroCanvas />

    <div class="hero-text">
      <span class="hero-badge">System Critical</span>

      <h1>
        When AI <span class="live-underline">fails</span>,<br />
        governance<br />
        decides.
      </h1>

      <p class="hero-sub">
        Building accountable protocols for high-stakes AI deployment.
        Moving beyond technical performance to ensure legitimacy and trust.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn btn--primary">Initiate Inquiry</a>
        <a href="/dossier" class="btn btn--outline">View Dossier</a>
      </div>
    </div>
  </section>

  <!-- FEATURED INSIGHTS -->
  {featured.length > 0 && (
    <section class="home-insights">
      <span class="section-label">Selected Insight</span>

      <div class="insights-grid">
        {featured.map((post) => {
          const href = post.data.external_url
            ? post.data.external_url
            : `/insights/${post.slug}`;
          const isExternal = !!post.data.external_url;

          return (
            <article class="insight-card live-spine">
              <time
                class="insight-date"
                datetime={post.data.date.toISOString()}
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric', month: 'long', day: 'numeric',
                })}
              </time>

              <h2 class="insight-title">
                <a
                  href={href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                >
                  {post.data.title}
                </a>
              </h2>

              <p class="insight-desc">{post.data.description}</p>

              <a
                href={href}
                class="read-more"
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
              >
                Read Dispatch →
              </a>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <!-- CORE MODULES -->
  <section class="home-modules">
    <span class="section-label">Core Modules</span>
    <div class="modules-grid">
      <div class="module-card">
        <span class="module-num">01</span>
        <h3 class="module-title">Accountability</h3>
        <p class="module-desc">
          Designing auditing trails that ensure every AI decision
          is traceable and defensible.
        </p>
      </div>
      <div class="module-card">
        <span class="module-num">02</span>
        <h3 class="module-title">Risk Architecture</h3>
        <p class="module-desc">
          Deployment frameworks that isolate high-risk agents
          and prevent systemic failure.
        </p>
      </div>
      <div class="module-card">
        <span class="module-num">03</span>
        <h3 class="module-title">Legitimacy</h3>
        <p class="module-desc">
          Real-time alignment with EU AI Act and global standards.
          Turn regulation into a strategic advantage.
        </p>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── HERO ───────────────────────────────────────────────── */
  .hero {
    position: relative;
    margin-top: 64px;
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding: 80px 60px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-text {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--live-text);
    margin-bottom: 28px;
  }

  .hero-badge::before {
    content: '';
    display: inline-block;
    width: 22px;
    height: 1.5px;
    background: var(--live);
  }

  .hero h1 {
    font-size: clamp(3rem, 5.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--ink-soft);
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ── FEATURED INSIGHTS ──────────────────────────────────── */
  .home-insights {
    padding: 80px 60px;
    border-bottom: 1px solid var(--border);
    max-width: 1100px;
    margin: 0 auto;
  }

  .insights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    position: relative;
  }

  .insights-grid::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    height: 100%;
    width: 1px;
    background: var(--border);
  }

  .insight-card { display: flex; flex-direction: column; }

  .insight-date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-soft);
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .insight-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .insight-title a { transition: color 0.2s; }
  .insight-title a:hover { color: var(--live-text); }

  .insight-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.65;
    margin-bottom: 20px;
    flex: 1;
  }

  .read-more {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--live-text);
    border-bottom: 1px solid var(--live-text);
    padding-bottom: 2px;
    width: fit-content;
    transition: opacity 0.2s;
  }

  .read-more:hover { opacity: 0.7; }

  /* ── CORE MODULES ───────────────────────────────────────── */
  .home-modules {
    padding: 80px 60px 100px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .module-card {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 36px 28px;
    position: relative;
    transition: border-color 0.25s, transform 0.25s;
  }

  .module-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 2px;
    background: var(--live);
    transition: width 0.3s ease;
  }

  .module-card:hover::before { width: 100%; }
  .module-card:hover {
    border-color: rgba(79, 110, 247, 0.25);
    transform: translateY(-4px);
  }

  .module-num {
    display: block;
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 600;
    color: rgba(79, 110, 247, 0.15);
    line-height: 1;
    margin-bottom: 16px;
  }

  .module-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .module-desc {
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero { padding: 60px 24px; min-height: 80vh; }

    .home-insights { padding: 60px 24px; }
    .insights-grid { grid-template-columns: 1fr; gap: 48px; }
    .insights-grid::after { display: none; }

    .home-modules { padding: 60px 24px 80px; }
    .modules-grid { grid-template-columns: 1fr; }
  }
</style>
